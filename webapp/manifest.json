{
	"_version": "1.48.0",
	"sap.app": {
		"id": "procurement.risk.dashboard",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"applicationVersion": {
			"version": "1.0.0"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"sourceTemplate": {
			"id": "ui5template.basicSAPUI5ApplicationProject",
			"version": "1.40.12"
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": false,
		"dependencies": {
			"minUI5Version": "1.120.23",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.ui.layout": {},
				"sap.f": {},
				"sap.ui.comp": {},
				"sap.viz": {},
				"sap.ui.export": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "procurement.risk.dashboard.i18n.i18n"
				}
			}
		},
		"resources": {
			"css": [
				{
					"uri": "css/style.css"
				}
			]
		},
		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"viewType": "XML",
				"viewPath": "procurement.risk.dashboard.view",
				"controlId": "mainApp",
				"controlAggregation": "pages",
				"bypassed": {
					"target": "dashboard"
				},
				"async": true
			},
			"routes": [
				{
					"pattern": "",
					"name": "dashboard",
					"target": "dashboard"
				},
				{
					"pattern": "suppliers",
					"name": "supplierList",
					"target": "supplierList"
				},
				{
					"pattern": "suppliers/{supplierId}",
					"name": "supplierDetail",
					"target": "supplierDetail"
				}
			],
			"targets": {
				"dashboard": {
					"viewName": "Dashboard",
					"viewLevel": 1,
					"title": "{{targetDashboardTitle}}"
				},
				"supplierList": {
					"viewName": "SupplierList",
					"viewLevel": 2,
					"title": "{{targetSupplierListTitle}}"
				},
				"supplierDetail": {
					"viewName": "SupplierDetail",
					"viewLevel": 3,
					"title": "{{targetSupplierDetailTitle}}"
				}
			}
		},
		"rootView": {
			"viewName": "procurement.risk.dashboard.view.App",
			"type": "XML",
			"id": "app",
			"async": true
		}
	}
}
